
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}


enum Role {
  SUPER_ADMIN
  USER
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  nid       String
  phone     String
  imageId   String?
  imageUrl  String?
  terms     Boolean  @default(false)
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}